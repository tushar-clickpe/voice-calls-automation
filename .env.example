# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-random-string

# SQLite database path (relative to project root)
DATABASE_PATH=data/campaigns.db

# Google Sheets - path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json

# n8n webhook URLs (one per campaign slot, add more if needed)
# These are the webhook trigger URLs from your n8n workflows
N8N_WEBHOOK_URL_1=https://your-n8n-instance.com/webhook/campaign-1
N8N_WEBHOOK_URL_2=https://your-n8n-instance.com/webhook/campaign-2
N8N_WEBHOOK_URL_3=https://your-n8n-instance.com/webhook/campaign-3

# Callback URL - the URL n8n will POST results back to
# This should be your app's public URL
CALLBACK_BASE_URL=http://your-server-ip:8000

# Default campaign settings
DEFAULT_BATCH_SIZE=100
DEFAULT_MAX_ATTEMPTS=2
DEFAULT_DAILY_TARGET=400
